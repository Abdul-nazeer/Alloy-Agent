# LLM API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here  # Optional for Claude

# Model Configuration
PRIMARY_MODEL=phi3-finetuned  # phi3-finetuned or gpt-4o-mini
FALLBACK_MODEL=gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alloy_maintenance
POSTGRES_USER=alloy_user
POSTGRES_PASSWORD=your_secure_password

# ChromaDB
CHROMADB_PATH=./data/chromadb
CHROMADB_COLLECTION=maintenance_knowledge

# InfluxDB (Optional for real deployment)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influx_token
INFLUXDB_ORG=alloy_plant
INFLUXDB_BUCKET=sensor_data

# Neo4j (Optional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Application Settings
APP_ENV=development  # development, production
DEBUG=true
LOG_LEVEL=INFO

# Fine-Tuned Model Path
FINETUNED_MODEL_PATH=./models/fine_tuned_phi3
ADAPTER_PATH=./models/fine_tuned_phi3/adapter_model.safetensors

# IoT Simulation
ENABLE_IOT_SIMULATION=true
SIMULATION_FREQUENCY_MS=1000  # Update every 1 second
INJECT_ANOMALIES=true

# Alerting
ALERT_CHECK_INTERVAL=5  # Seconds
ENABLE_EMAIL_ALERTS=false  # Set to true for production
ALERT_EMAIL=alerts@alloyplant.com

# Dashboard
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
API_TIMEOUT_SECONDS=30

# Feature Flags
ENABLE_FEEDBACK_LOOP=true
ENABLE_ROLE_BASED_ACCESS=true
ENABLE_DIGITAL_LOGBOOK=true
ENABLE_PDF_EXPORT=true

# Data Generation (for initial setup)
SYNTHETIC_DATA_COUNT=400
USE_GPT4_FOR_GENERATION=true
GPT4_TEMPERATURE=0.8
