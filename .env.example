# Qdrant Configuration
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io
QDRANT_API_KEY=your_api_key_here

# HuggingFace Configuration
HF_TOKEN=your_huggingface_token_here

# Environment
ENVIRONMENT=development

# Model Configuration
LLM_MODEL=abdul-nazeer/alloy-agent-phi3-maintenance

# API Usage Control (for free tier Groq API optimization)
# Options: "balanced" (default - 6 reports/hour), "production" (20/hour), "conservative" (3/hour)
# balanced: AI for CRITICAL/HIGH, templates for MEDIUM
# production: AI for all severity levels
# conservative: AI only for CRITICAL
API_USAGE_MODE=balanced

# Autonomous Monitoring (background loop that checks equipment every 30s)
# Set to "true" to enable automatic anomaly detection and reporting
# Set to "false" (default) for demo mode - use "DEMO ANOMALY" button instead
# Default: false (demo mode - prevents automatic API calls)
ENABLE_AUTONOMOUS_MONITORING=false
